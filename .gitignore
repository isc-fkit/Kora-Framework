# ===== Bảo mật =====
**/.env.local
tools/jira-to-obsidian/.env.local
# Env per-source (mỗi nguồn Jira 1 file) — DATA của user, KHÔNG commit. Giữ lại .env.example làm template.
tools/jira-to-obsidian/.env.*
!tools/jira-to-obsidian/.env.example
# Confluence-sync: env (kể cả read-cred ship trong archive) + token OAuth — DATA, KHÔNG commit.
tools/confluence-sync/.env.*
!tools/confluence-sync/.env.example
tools/confluence-sync/.oauth-token.json
# GitHub-sync: PAT (.env) + worktree làm việc — DATA/máy-cục-bộ, KHÔNG commit. Giữ .env.example.
tools/github-sync/.env.*
!tools/github-sync/.env.example
tools/github-sync/work/
tools/gitlab-sync/.env.*
!tools/gitlab-sync/.env.example
tools/gitlab-sync/work/
# Lịch cấp HĐH (DATA, máy-cục-bộ) — registry + log. Plist/crontab nằm NGOÀI repo.
tools/kora-scheduler/schedules.json
reports/scheduler-logs/

# ===== KHÔNG public nội dung nghiệp vụ (chỉ host trang giới thiệu) =====
# Bỏ comment các dòng dưới nếu muốn GIỮ KB ở local, chỉ đẩy landing page + source code:
docs/01-domain/
docs/02-product/
docs/03-features/
docs/04-design/
docs/05-architecture/
docs/06-decisions/
docs/08-glossary/
inbox/
reports/
*_Brain/
Project_Name_Brain/
.kb/index.json
.kb/relation-graph.json
.kb/source-registry.json
.kb/health-report.md
.kb/lessons.md
.kb/changelog.md

# ===== Cấu hình của user (DATA — không commit, được giữ khi update) =====
# Các file này do user điền lúc setup. Bản template đi kèm repo là factory-config.example.yaml
# và config/domain-presets/ — copy ra rồi chỉnh, KHÔNG đẩy bản thật lên git.
config/factory-config.yaml
config/domain-rules.md

# ===== Gói export / archive tri thức (tạo bởi scripts/export-kb, archive-kb) — không commit =====
genesis1-kb-*.zip
kora-kb-*.zip
kora-archive-*.zip

# ===== Đánh dấu máy người duy trì (bật quyền "phát hành") — local-only =====
.maintainer
# ===== Đánh dấu gói "user" (tắt report/mail, bật get&post) — local-only =====
.kora-user

# ===== Rác hệ thống =====
.DS_Store
__pycache__/
*.pyc
.venv/

# Local preview/dev config (không publish)
.claude/*
# ...nhưng slash commands thì publish để app/web cùng dùng
!.claude/commands/
