# tools/sharepoint-sync/.env.local — copy file này thành .env.local rồi điền.
# KHÔNG commit .env.local (đã gitignore). Token KHÔNG vào chat/config/git.
#
# Ưu tiên đặt ở SHELL ENV (~/.zshrc: export SHAREPOINT_...=...); CHỈ tạo .env.local cho LỊCH NỀN
# (cron/launchd không đọc được shell tương tác).
#
# ── Cách 1 — APP-ONLY (client-credentials): CHẠY NỀN được. Cần admin consent Sites.ReadWrite.All ──
SHAREPOINT_TENANT_ID=PASTE_TENANT_ID          # vd: contoso.onmicrosoft.com hoặc GUID tenant
SHAREPOINT_CLIENT_ID=PASTE_APP_CLIENT_ID      # App (client) ID của app đăng ký Azure AD
SHAREPOINT_CLIENT_SECRET=PASTE_CLIENT_SECRET  # Client secret của app
#
# ── Cách 2 — DEVICE-FLOW (delegated): chỉ tương tác. Chạy `--login` 1 lần (chỉ cần CLIENT_ID[+TENANT]) ──
# SHAREPOINT_TENANT_ID=common
# SHAREPOINT_CLIENT_ID=PASTE_APP_CLIENT_ID
#
# Tùy chọn (thường để trong config/factory-config.yaml, không cần ở đây):
# SHAREPOINT_BASE_URL=https://<tenant>.sharepoint.com
# SHAREPOINT_AUTH=auto                          # auto | client_credentials | device
