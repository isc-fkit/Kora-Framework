# Copy file này thành .env.local rồi điền giá trị. KHÔNG commit .env.local.

JIRA_BASE_URL=https://jira.congty.vn

# --- XÁC THỰC: chọn đúng loại Jira của bạn ---
# A) Jira Server / Data Center (tự host, vd https://jira.fptmedicare.vn):
#    Chỉ cần JIRA_PAT (Personal Access Token). Để JIRA_EMAIL trống.
# B) Jira Cloud / Atlassian (https://<tên>.atlassian.net):
#    Cần JIRA_EMAIL (email tài khoản) + JIRA_PAT là API token.
#    Tạo token: avatar (góc phải) > Account settings > Security >
#               "Create and manage API tokens" > Create API token > copy.
#    Link nhanh: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_PAT=PASTE_TOKEN_MOI_VAO_DAY
# auto = tự nhận (URL atlassian.net hoặc có JIRA_EMAIL → Cloud). Ép: cloud | server
JIRA_AUTH_MODE=auto

# ⬇️ NƠI LƯU KẾT QUẢ — quan trọng!
# OBSIDIAN_VAULT = đường dẫn THƯ MỤC mà script sẽ tạo toàn bộ notes vào đó.
# Đây chính là thư mục bạn mở trong Obsidian ("Open folder as vault").
# Mặc định ../../Project_Name_Brain = thư mục vault (bộ não tri thức) của project này.
# Lúc setup, Claude đổi tên này theo tên project thật: <TênProject>_Brain
# (đường dẫn tương đối tính từ tools/jira-to-obsidian/ — nơi chạy script).
# Có thể thay bằng đường dẫn tuyệt đối, vd:
# OBSIDIAN_VAULT=/Users/ten-ban/Documents/MyVault
OBSIDIAN_VAULT=../../Project_Name_Brain

# Để trống = quét tất cả project account thấy được. Ví dụ: PROJECT_KEYS=FPT,CGM
PROJECT_KEYS=

# Gom notes theo project: true = mỗi project Jira một thư mục con trong vault
# (vd FA/02_Epics/..., FC/02_Epics/...). 00_Index và _system vẫn dùng chung.
# Khuyến nghị bật khi quét nhiều project. false = tất cả chung một cây thư mục.
GROUP_BY_PROJECT=true

# (Tùy chọn) Đổi tên thư mục trong vault — JSON, chỉ điền key muốn đổi.
# Các key: index, projects, epic, story, user_story, task, bug, sub-task, raw, system
# Ví dụ: VAULT_DIRS=

# (Tùy chọn) Jira đặt tên loại issue khác chuẩn (vd tiếng Việt) → khai báo mapping JSON.
# Loại chuẩn: epic | user_story | task | bug | sub-task
# Ví dụ: JIRA_TYPE_MAP=

# (Tùy chọn) Mẫu tên thư mục mỗi project trong vault (khi GROUP_BY_PROJECT=true).
# Placeholder: {key} = mã project, {name} = tên project. Mặc định: {key}_{name}
# Vd: {key}_{name} → FA_FMC-App | {name} → FMC-App | {key} → FA
PROJECT_FOLDER_PATTERN={"câu chuyện":"user_story","sử thi":"epic","lỗi":"bug"}
JIRA_TYPE_MAP=

# (Tùy chọn) Mẫu tên thư mục mỗi project trong vault (khi GROUP_BY_PROJECT=true).
# Placeholder: {key} = mã project, {name} = tên project. Mặc định: {key}_{name}
# Vd: {key}_{name} → FA_FMC-App | {name} → FMC-App | {key} → FA
PROJECT_FOLDER_PATTERN={"epic":"Epics","user_story":"Stories","index":"_MucLuc"}
VAULT_DIRS=

# (Tùy chọn) Jira đặt tên loại issue khác chuẩn (vd tiếng Việt) → khai báo mapping JSON.
# Loại chuẩn: epic | user_story | task | bug | sub-task
# Ví dụ: JIRA_TYPE_MAP=

# (Tùy chọn) Mẫu tên thư mục mỗi project trong vault (khi GROUP_BY_PROJECT=true).
# Placeholder: {key} = mã project, {name} = tên project. Mặc định: {key}_{name}
# Vd: {key}_{name} → FA_FMC-App | {name} → FMC-App | {key} → FA
PROJECT_FOLDER_PATTERN={"câu chuyện":"user_story","sử thi":"epic","lỗi":"bug"}
JIRA_TYPE_MAP=

# (Tùy chọn) Mẫu tên thư mục mỗi project trong vault (khi GROUP_BY_PROJECT=true).
# Placeholder: {key} = mã project, {name} = tên project. Mặc định: {key}_{name}
# Vd: {key}_{name} → FA_FMC-App | {name} → FMC-App | {key} → FA
PROJECT_FOLDER_PATTERN=

# Custom field id cho Acceptance Criteria / Business Rule nếu Jira có (vd customfield_10101)
JIRA_AC_FIELD=
JIRA_BR_FIELD=
