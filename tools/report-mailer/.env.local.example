# tools/report-mailer/.env.local — bí mật để gửi báo cáo qua email.
# ĐÃ gitignore (qua **/.env.local). KHÔNG commit, KHÔNG dán vào chat.
# Copy file này thành .env.local (cùng thư mục) rồi điền giá trị thật.
#
# GMAIL: cần BẬT xác thực 2 bước (2FA), rồi tạo "App Password" 16 ký tự tại:
#   https://myaccount.google.com/apppasswords
# Dán App Password vào SMTP_PASS (KHÔNG dùng mật khẩu đăng nhập Gmail thường — sẽ bị từ chối).
#
# SMTP_SECURITY: starttls (cổng 587, khuyến nghị) | ssl (cổng 465)
# Outlook/Office365 (nếu org cho phép SMTP AUTH): SMTP_HOST=smtp.office365.com, PORT=587, starttls.

# DÙNG TÀI KHOẢN GỬI CHUYÊN DỤNG (vd ftel.medicare@gmail.com) — KHÔNG dùng email cá nhân/đăng nhập của bạn.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=ftel.medicare@gmail.com
SMTP_PASS=PASTE_APP_PASSWORD_HERE
MAIL_FROM=ftel.medicare@gmail.com
# Tên người gửi HIỂN THỊ cho người nhận (đổi tự do). Người nhận thấy: "Báo cáo tiến độ <ftel.medicare@gmail.com>".
MAIL_FROM_NAME=Báo cáo tiến độ

# ── (TUỲ CHỌN) FALLBACK Gmail API/HTTPS — BẬT khi mạng chặn MỌI cổng SMTP (firewall công ty) ──
# Khi gửi SMTP lỗi vì kết nối, send_report.py TỰ gửi lại CÙNG email qua Gmail API (HTTPS 443),
# định tuyến qua proxy công ty. Lấy 3 key 1 lần bằng:
#   python3 tools/report-mailer/gmail_oauth_setup.py --client-id <ID> --client-secret <SECRET>
# (Tạo OAuth client "Desktop app" + bật Gmail API ở Google Cloud Console. NÊN Publish app để token bền.)
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_API_USER=me                          # hoặc địa chỉ Gmail nếu dùng alias "Send mail as"
# HTTPS_PROXY=http://proxy.hcm.fpt.vn:80      # proxy cho CONNECT 443 (bắt buộc trên mạng chặn SMTP)
# SMTP_TIMEOUT=15                            # giây chờ SMTP trước khi fallback (mặc định 15)
