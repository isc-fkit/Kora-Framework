# Copy thành .env.local (đã gitignore). KHÔNG commit file .env.local.
# PAT GitLab (scope 'api', hoặc 'read_repository'+'write_repository') — quyền ghi repo đích.
KORA_GITLAB_SYNC_TOKEN=PASTE_YOUR_PAT_HERE

# (Tùy chọn) Danh tính tác giả commit. Mặc định "Kora Sync <kora-sync@local>".
# KORA_GITLAB_SYNC_AUTHOR_NAME=Kora Sync
# KORA_GITLAB_SYNC_AUTHOR_EMAIL=kora-sync@local
