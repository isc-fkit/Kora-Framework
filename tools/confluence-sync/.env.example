# tools/confluence-sync/.env.example — copy thành .env.local rồi điền (đã gitignore).
# KHÔNG commit .env.local. KHÔNG dán token vào chat.

CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki

# ── Cách A: API token (đơn giản nhất, HỢP cho cron/scheduler chạy nền) ──
# Tạo token tại: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=PASTE_TOKEN_HERE

# ── Cách B: OAuth 2.0 (3LO) — ưu tiên cho thao tác do người chạy (--login) ──
# Tạo OAuth 2.0 app tại: https://developer.atlassian.com/console/myapps/
# CONFLUENCE_OAUTH_CLIENT_ID=PASTE_CLIENT_ID
# CONFLUENCE_OAUTH_CLIENT_SECRET=PASTE_SECRET
# CONFLUENCE_OAUTH_SCOPES=read:confluence-content.all write:confluence-content offline_access
# CONFLUENCE_OAUTH_REDIRECT=http://localhost:8765/callback

# auto = có .oauth-token.json thì dùng OAuth, không thì dùng API token. (auto|oauth|token)
CONFLUENCE_AUTH=auto
