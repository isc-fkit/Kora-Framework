# Copy thành .env.local (đã gitignore). KHÔNG commit file .env.local.
# PAT GitHub (scope 'repo') — chỉ cần quyền ghi vào repo private đích.
KORA_GITHUB_SYNC_TOKEN=PASTE_YOUR_PAT_HERE

# (Tùy chọn) Danh tính tác giả commit. Mặc định "Kora Sync <kora-sync@local>".
# KORA_GITHUB_SYNC_AUTHOR_NAME=Kora Sync
# KORA_GITHUB_SYNC_AUTHOR_EMAIL=kora-sync@local
